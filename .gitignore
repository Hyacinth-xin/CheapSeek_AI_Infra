# ============================================================
# C/C++ 编译产物
# ============================================================

# 目标文件
*.o
*.obj

# 静态/共享库
*.a
# *.so
!**/lib/libaec_device.so

# 可执行文件
*.exe
*.out

# 构建输出目录
bin/
build/
dist/

# 编译生成的 kernel 镜像（官方测试用的 kernels/images/ 保留）
*.aecbin
!C2-runtime/kernels/images/*.aecbin

# C2-runtime 构建产物
C2-runtime/libaec.so

# ============================================================
# Python
# ============================================================

# 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 分发
*.egg-info/
*.egg

# 虚拟环境
.venv/
venv/
env/

# 测试/覆盖率
.pytest_cache/
.coverage
htmlcov/

# ============================================================
# IDE / 编辑器
# ============================================================

# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# ============================================================
# 操作系统
# ============================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
._*

# ============================================================
# 日志 / 临时文件
# ============================================================

*.log
*.tmp
*.temp
*.bak

# ============================================================
# 大型数据文件（二进制测试数据/模型）
# ============================================================

# NumPy 数据文件（测试输入输出，体积大）
*.npy

# ONNX 模型文件（体积较大，可由模型训练脚本生成）
*.onnx

# ============================================================
# 项目特定
# ============================================================

# 评分中间结果
results/
output/

# Claude AI 上下文文件（个人使用）
CLAUDE.md

# 测试用的压力脚本
# C2 测试脚本
C2-runtime/test/